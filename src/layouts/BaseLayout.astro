---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Digital Garden',
  description = 'A repo-centric personal homepage for ideas, code, and physics.',
} = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const homeHref = baseUrl;
const aboutHref = `${baseUrl}#about`;
const faviconHref = `${baseUrl}favicon.svg`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07070f" />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-nav glass">
      <nav class="container nav-inner">
        <a href={homeHref} class="nav-logo" aria-label="Home">
          <span class="logo-icon">⬡</span>
          <span class="logo-text">Digital Garden</span>
        </a>
        <div class="nav-links">
          <a href={homeHref} class="nav-link">Projects</a>
          <a href={aboutHref} class="nav-link">About</a>
          <a href="https://github.com" target="_blank" rel="noopener" class="nav-link nav-link-github">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
            </svg>
            GitHub
          </a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <span class="footer-text">Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> · Repo-Centric Digital Garden</span>
        <span class="footer-text">© 2026 Langxu Bai</span>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--nav-height);
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--border-subtle);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--text-primary);
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    transition: color var(--transition-fast);
  }

  .nav-logo:hover { color: var(--accent-primary); }

  .logo-icon {
    font-size: 1.4rem;
    color: var(--accent-primary);
    filter: drop-shadow(0 0 6px var(--accent-glow));
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
    transition: all var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--text-primary);
    background: var(--bg-elevated);
  }

  .nav-link-github {
    border: 1px solid var(--border-normal);
    color: var(--text-primary);
  }

  .nav-link-github:hover {
    border-color: var(--border-accent);
    color: var(--accent-primary);
    box-shadow: 0 0 10px var(--accent-glow);
  }

  .site-footer {
    border-top: 1px solid var(--border-subtle);
    padding: var(--space-8) 0;
    margin-top: var(--space-20);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .footer-text {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .footer-text a {
    color: var(--text-secondary);
  }
  .footer-text a:hover { color: var(--accent-primary); }
</style>
